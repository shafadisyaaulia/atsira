# ============================================================================
# ATSIRA — Environment Variables
# Salin file ini ke .env.local lalu isi dengan kredensial Anda sendiri.
# Untuk Fase 1 (mock data), file ini TIDAK WAJIB diisi — web tetap berjalan.
# Hanya diperlukan saat masuk ke Fase 2 (database & AI real).
# ============================================================================

# --- Supabase (Fase 2 — Database) ---
# Daftar gratis di https://supabase.com, buat project baru, lalu ambil dari
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini (Fase 2 — Nilam Analyzer AI, vision) ---
# Dapatkan API key gratis di https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Groq (Fase 2 — AtBot chat assistant) ---
# Dapatkan API key gratis di https://console.groq.com/keys
GROQ_API_KEY=
